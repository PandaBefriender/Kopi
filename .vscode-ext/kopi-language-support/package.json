{
  "name": "kopi-language-support",
  "publisher": "kopi-org",
  "displayName": "Kopi Language Support",
  "description": "Syntax highlighting and language support for Kopi programming language",
  "version": "1.1.0",
  "icon": "./icons/kopi.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kopi",
        "aliases": [
          "Kopi",
          "kopi"
        ],
        "extensions": [
          ".kopi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kopi.png",
          "dark": "./icons/kopi.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kopi",
        "scopeName": "source.kopi",
        "path": "./kopi.tmLanguage.json"
      }
    ]
  },
  "keywords": [
    "kopi",
    "programming",
    "language"
  ]
}

