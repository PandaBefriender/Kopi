{
  "name": "kopi-language",
  "displayName": "Kopi Language",
  "description": "Kopi programming language support for VS Code",
  "version": "1.0.0",
  "publisher": "kopi",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kopi",
        "aliases": [
          "Kopi",
          "kopi"
        ],
        "extensions": [
          ".kopi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kopi-light.svg",
          "dark": "./icons/kopi-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kopi",
        "scopeName": "source.kopi",
        "path": "./kopi.tmLanguage.json"
      }
    ]
  }
}
