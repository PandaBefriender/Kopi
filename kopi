#!/bin/bash

# Kopi language interpreter wrapper
# Usage: kopi run <file>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ "$1" = "run" ] || [ "$1" = "" ]; then
    if [ "$1" = "run" ]; then
        shift
    fi
    
    if [ -z "$1" ]; then
        echo "Usage: kopi run <file.kopi>"
        exit 1
    fi
    
    python3 "$SCRIPT_DIR/main.kopi" "$@"
else
    echo "Unknown command: $1"
    echo "Usage: kopi run <file.kopi>"
    exit 1
fi
