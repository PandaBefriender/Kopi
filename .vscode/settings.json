{
  "files.associations": {
    "*.kopi": "kopi"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword.control.kopi",
        "settings": {
          "foreground": "#569CD6",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "comment.line.kopi",
        "settings": {
          "foreground": "#6A9955",
          "fontStyle": "italic"
        }
      },
      {
        "scope": "string.quoted.double.kopi",
        "settings": {
          "foreground": "#CE9178"
        }
      },
      {
        "scope": "constant.numeric.kopi",
        "settings": {
          "foreground": "#B5CEA8"
        }
      },
      {
        "scope": "support.function.kopi",
        "settings": {
          "foreground": "#DCDCAA"
        }
      },
      {
        "scope": "keyword.operator.kopi",
        "settings": {
          "foreground": "#D4D4D4"
        }
      }
    ]
  }
}